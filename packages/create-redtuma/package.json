{
  "name": "create-redtuma",
  "version": "0.1.0",
  "description": "Scaffold a new Redtuma project — `npm create redtuma@latest`.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "create-redtuma": "./bin/create-redtuma.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redtuma/redtuma.git",
    "directory": "packages/create-redtuma"
  },
  "homepage": "https://redtuma.ai",
  "bugs": "https://github.com/redtuma/redtuma/issues",
  "keywords": [
    "ai",
    "agents",
    "llm",
    "typescript",
    "redtuma",
    "vercel-ai-sdk"
  ]
}
