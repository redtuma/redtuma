{
  "name": "redtuma",
  "version": "0.1.2",
  "description": "Redtuma CLI: scaffold, dev server and build for Redtuma projects.",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "bin": {
    "redtuma": "./bin/redtuma.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@redtuma/core": "workspace:*",
    "@redtuma/deployer": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "cac": "^6.7.14",
    "hono": "^4.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redtuma/redtuma.git",
    "directory": "packages/cli"
  },
  "homepage": "https://redtuma.ai",
  "bugs": "https://github.com/redtuma/redtuma/issues",
  "keywords": [
    "ai",
    "agents",
    "llm",
    "typescript",
    "redtuma",
    "vercel-ai-sdk"
  ]
}
