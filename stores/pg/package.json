{
  "name": "@chituma/store-pg",
  "version": "0.1.0",
  "description": "Chituma PostgreSQL store adapter.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
